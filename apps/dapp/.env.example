# WalletConnect project ID — required for wallet connections
# Get one at https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_ID=

# Alchemy API key — used for RPC provider (optional, fallback to public RPCs)
NEXT_PUBLIC_ALCHEMY_ID=

# Infura API key — used for RPC provider (optional, fallback to public RPCs)
NEXT_PUBLIC_INFURA_ID=

# Enable debug logging in shared package (set to "true" to enable)
NEXT_PUBLIC_DEBUG_LOGS=

# Neynar API key — required for Farcaster user search and bot features
# Get one at https://neynar.com/
NEYNAR_API_KEY=

# Neynar bot signer UUID — required for Farcaster bot webhook responses
NEYNAR_BOT_SIGNER_UUID=

# Neynar webhook secret — used to verify incoming Farcaster webhook requests
NEYNAR_WEBHOOK_SECRET=

# Neynar signer UUID — used for sending Farcaster notifications (cast replies)
NEYNAR_SIGNER_UUID=

# OpenAI API key — powers the /api/chat support chatbot
OPENAI_API_KEY=

# Telegram bot token — used for sending Telegram notifications
TELEGRAM_BOT_TOKEN=

# Telegram chat ID — target chat for Telegram notifications
TELEGRAM_CHAT_ID=

# Farcaster FID to notify — target user for Farcaster direct casts
NOTIFY_FARCASTER_FID=

# Shared secret for the /api/notify endpoint authentication
NOTIFY_API_SECRET=

# Set to "true" to enable Next.js bundle analyzer
ANALYZE=
